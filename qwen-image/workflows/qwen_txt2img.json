{
  "_doc": "Qwen-Image txt2img (ComfyUI API format) for cb-qwenimage. content-studio sends {\"input\":{\"workflow\": <this>}} with {prompt}/{width}/{height}/{seed} substituted (resolver.js fills the SAME prompt that drives previews + real assets). 8-step Lightning LoRA path. NOTE: verify node names + model filenames on first deploy against the official template (Comfy-Org/workflow_templates image_qwen_image) — adjust if ComfyUI reports an unknown node or missing model.",
  "10": { "class_type": "UNETLoader",        "inputs": { "unet_name": "qwen_image_fp8_e4m3fn.safetensors", "weight_dtype": "default" } },
  "11": { "class_type": "CLIPLoader",        "inputs": { "clip_name": "qwen_2.5_vl_7b_fp8_scaled.safetensors", "type": "qwen_image" } },
  "12": { "class_type": "VAELoader",         "inputs": { "vae_name": "qwen_image_vae.safetensors" } },
  "14": { "class_type": "LoraLoaderModelOnly", "inputs": { "lora_name": "Qwen-Image-Lightning-8steps-V2.0.safetensors", "strength_model": 1.0, "model": ["10", 0] } },
  "15": { "class_type": "ModelSamplingAuraFlow", "inputs": { "shift": 3.1, "model": ["14", 0] } },
  "6":  { "class_type": "CLIPTextEncode",    "inputs": { "text": "{prompt}", "clip": ["11", 0] } },
  "7":  { "class_type": "CLIPTextEncode",    "inputs": { "text": "blurry, low quality, watermark, text, deformed, distorted face, extra limbs", "clip": ["11", 0] } },
  "5":  { "class_type": "EmptySD3LatentImage", "inputs": { "width": "{width}", "height": "{height}", "batch_size": 1 } },
  "13": { "class_type": "KSampler",          "inputs": { "seed": "{seed}", "steps": 8, "cfg": 1.0, "sampler_name": "euler", "scheduler": "simple", "denoise": 1, "model": ["15", 0], "positive": ["6", 0], "negative": ["7", 0], "latent_image": ["5", 0] } },
  "8":  { "class_type": "VAEDecode",         "inputs": { "samples": ["13", 0], "vae": ["12", 0] } },
  "9":  { "class_type": "SaveImage",         "inputs": { "filename_prefix": "cbqwen", "images": ["8", 0] } }
}
