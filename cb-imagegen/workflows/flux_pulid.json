{
  "_doc": "FLUX + PuLID face-lock (ComfyUI API format) for cb-imagegen. The client's face is sent alongside as input image 'face.png' (RunPod worker-comfyui: {\"input\":{\"workflow\":<this>,\"images\":[{\"name\":\"face.png\",\"image\":\"<base64>\"}]}}). ApplyPulidFlux conditions the generation on that identity. {prompt}/{width}/{height}/{seed} substituted by resolver. Verify node names on first deploy against sipie800/ComfyUI-PuLID-Flux-Enhanced if ComfyUI reports an unknown node.",
  "4":  { "class_type": "CheckpointLoaderSimple", "inputs": { "ckpt_name": "flux1-dev-fp8.safetensors" } },
  "20": { "class_type": "PulidFluxModelLoader", "inputs": { "pulid_file": "pulid_flux_v0.9.1.safetensors" } },
  "21": { "class_type": "PulidFluxEvaClipLoader", "inputs": {} },
  "22": { "class_type": "PulidFluxInsightFaceLoader", "inputs": { "provider": "CUDA" } },
  "23": { "class_type": "LoadImage", "inputs": { "image": "face.png" } },
  "24": { "class_type": "ApplyPulidFlux", "inputs": { "model": ["4", 0], "pulid_flux": ["20", 0], "eva_clip": ["21", 0], "face_analysis": ["22", 0], "image": ["23", 0], "weight": 0.9, "start_at": 0, "end_at": 1 } },
  "6":  { "class_type": "CLIPTextEncode", "inputs": { "text": "{prompt}", "clip": ["4", 1] } },
  "7":  { "class_type": "CLIPTextEncode", "inputs": { "text": "blurry, low quality, watermark, text, deformed, distorted face", "clip": ["4", 1] } },
  "5":  { "class_type": "EmptySD3LatentImage", "inputs": { "width": "{width}", "height": "{height}", "batch_size": 1 } },
  "3":  { "class_type": "KSampler", "inputs": { "seed": "{seed}", "steps": 20, "cfg": 1, "sampler_name": "euler", "scheduler": "simple", "denoise": 1, "model": ["24", 0], "positive": ["6", 0], "negative": ["7", 0], "latent_image": ["5", 0] } },
  "8":  { "class_type": "VAEDecode", "inputs": { "samples": ["3", 0], "vae": ["4", 2] } },
  "9":  { "class_type": "SaveImage", "inputs": { "filename_prefix": "cbface", "images": ["8", 0] } }
}
